# Flask
FLASK_SECRET_KEY=change_me_to_a_long_random_secret
FLASK_DEBUG=0
FLASK_HOST=127.0.0.1
FLASK_PORT=5000

# Session cookie
# 1 en production HTTPS, 0 en local HTTP
SESSION_COOKIE_SECURE=0

# CORS (liste separee par des virgules)
CORS_ALLOWED_ORIGINS=http://localhost:5000,http://127.0.0.1:5000

# PostgreSQL
DB_HOST=localhost
DB_NAME=crypto_final
DB_USER=postgres
DB_PASSWORD=123456
DB_PORT=5432
